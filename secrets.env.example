# ⚠️ این فایل نمونه است. مقادیر واقعی را در secrets.env بگذار.
# secrets.env را هرگز در گیت commit نکن.

# ---------- Trello ----------
TRELLO_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id
TRELLO_LIST_TODO=your_todo_list_id
TRELLO_LIST_INPROGRESS=your_inprogress_list_id
TRELLO_LIST_WAITING=your_waiting_list_id
TRELLO_LIST_INREVIEW=your_inreview_list_id
TRELLO_LIST_OWNER=your_owner_list_id

# ---------- Bale ----------
BALE_BOT_TOKEN=your_bale_bot_token
OWNER_CHAT=your_chat_id

# ---------- GitHub ----------
GITHUB_TOKEN=ghp_your_github_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name
